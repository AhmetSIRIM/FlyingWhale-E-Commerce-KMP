# Gradle
.gradle/
**/build/
!**/src/**/build/          # keep source dirs literally named "build"
.gradletasknamecache
gradle-app.setting

# Keep the Gradle wrapper committed (guard against any global *.jar ignore)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Kotlin 2.x build/session data (KMP, Kotlin/Native)
.kotlin/

# Local machine config (SDK path, etc.) — never commit
local.properties

# ── IDEs ──
# IntelliJ IDEA / Android Studio
.idea/
*.iml
*.iws
*.ipr
out/

# JetBrains Fleet
.fleet/

# Android Studio native build / profiling
captures/
.externalNativeBuild/
.cxx/
*.hprof

# ── OS / Editors ──
.DS_Store
*~
*.swp

# ── Android ──
*.log
*.apk
*.aab
*.ap_
*.dex
output-metadata.json

# Firebase config: contains project IDs (not server secrets). Uncomment to ignore.
# google-services.json

# ── iOS / Xcode ──
xcuserdata
*.xcuserstate
*.hmap
DerivedData/
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings

# iOS packaging artifacts
*.ipa
*.dSYM
*.dSYM.zip

# Swift Package Manager (Package.resolved is committed on purpose to lock versions)
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.build/

# CocoaPods (currently unused, kept as a guard)
Pods/

# Carthage (currently unused, kept as a guard)
Carthage/Build/

# ── Compiled output ──
bin/
gen/
*.class

# ── Signing & secrets — never commit ──
*.keystore
*.jks
keystore.properties
*.cer
*.p12
*.mobileprovision

# ── Web / Node (for a future web/wasm target) ──
node_modules/

# Note: when you add a web target, COMMIT kotlin-js-store/yarn.lock to lock JS dependency versions.
